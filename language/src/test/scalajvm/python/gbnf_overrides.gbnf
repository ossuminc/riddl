# Hand-maintained GBNF overrides for rules that cannot be
# auto-converted from EBNF due to negative lookahead patterns.
#
# The ebnf_to_gbnf.py converter merges these verbatim into the
# generated output, replacing the auto-converted versions.
#
# When the source EBNF changes one of these rules, the converter
# emits a warning so a human can update the override.

# any-char-except-end-comment:
# EBNF: /(?:[^*]|\*(?!\/))+/
# Matches one or more characters that are not the */ sequence.
# State machine: non-star, or star followed by non-slash.
any-char-except-end-comment ::= ([^*] | "*" [^/])+

# any-char-except-triple-backtick:
# EBNF: /(?:[^`]|`(?!``)|``(?!`))+/
# Matches one or more characters that are not the ``` sequence.
# State machine: non-backtick, single backtick followed by
# non-backtick, or double backtick followed by non-backtick.
any-char-except-triple-backtick ::= ([^`] | "`" [^`] | "``" [^`])+

# inline-comment:
# EBNF: /\/\*(?:[^*]|\*(?!\/))*\*\//
# Matches /* ... */ where body cannot contain */.
# State machine over the interior.
inline-comment ::= "/*" ([^*] | "*" [^/])* "*/"
